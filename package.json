{
  "name": "glycan.js",
  "version": "0.0.1",
  "description": "A tiny library for drawing glycans",
  "main": "./js/index.js",
  "module": "./js/main.js",
  "type": "module",
  "directories": {
    "test": "test"
  },
  "exports": {
    ".": {
      "browser" : "./js/main.js",
      "node" : "./js/main-node.js"
    },
    "./sugar": "./js/Sugar.js",
    "./iupac": "./js/io/CondensedIupac.js",
    "./io/condensediupac": "./js/io/CondensedIupac.js",
    "./fragmentor": "./js/Fragmentor.js",
    "./mass": "./js/Mass.js",
    "./io/glycoct": "./js/io/glycoct.js",
    "./reference_monosaccharides": "./js/reference_monosaccharides.js",
    "./io/carbbank": "./js/io/carbbank.js",
    "./renderers/text": "./js/SugarTextRenderer.js"
  },
  "dependencies": {
    "debug": "^4.4.1",
    "es6-tween": "^5.5.11",
    "esm": "3.2.25"
  },
  "devDependencies": {
    "@babel/core": "^7",
    "@babel/preset-env": "^7.4.5",
    "babel-loader": "^8.0.5",
    "core-js": "2",
    "esbuild": "0.25.10",
    "eslint": "^7.5.0",
    "jsdom": "^24.0.0",
    "karma": "^6.4.2",
    "karma-jsdom-launcher": "^17.0.0",
    "karma-qunit": "^4.1.2",
    "karma-sourcemap-loader": "^0.3.7",
    "karma-webpack": "^4.0.2",
    "precommit-hook": "^3.0.0",
    "qunit": "^2.9.2",
    "raw-loader": "^2.0.0",
    "webpack": "^4.47.0",
    "webpack-cli": "^4.7.0",
    "webpack-dev-server": "^4.15.1"
  },
  "scripts": {
    "test": "./node_modules/karma/bin/karma start karma.conf.cjs --single-run --browsers jsdom",
    "test-watch": "./node_modules/karma/bin/karma start karma.conf.cjs --browsers jsdom",
    "tracetest": "./scripts/trace_tests.sh",
    "build-web": "./node_modules/.bin/webpack -d --config webpack.config.cjs",
    "build-watch-web": "./node_modules/.bin/webpack --watch --config webpack.config.cjs",
    "server": "python ./scripts/simplehttpserver",
    "start": "./node_modules/webpack-dev-server/bin/webpack-dev-server.js",
    "lint": "./node_modules/.bin/eslint test/**/*.js js/*.js --fix",
    "validate": "npm ls"
  },
  "browserify": {
    "transform": [
      "babelify"
    ]
  },
  "files": ["js/", "lib/", "package.json", "sugars.svg"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hirenj/glycan.js.git"
  },
  "author": "",
  "license": "TBD",
  "pre-commit": [
    "jshint-pre-commit"
  ]
}
